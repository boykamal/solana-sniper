# ══════════════════════════════════════════════
#  SOLANA SNIPER — FRONTEND CONFIG
# ══════════════════════════════════════════════

# Rust backend API URL (empty = same origin via nginx proxy)
VITE_API_URL=

# WebSocket URL (empty = auto-detect from browser host)
VITE_WS_URL=

# Solana RPC endpoint — use Helius for speed
# Free: leave empty (uses public mainnet)
# Fast: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_RPC_ENDPOINT=
