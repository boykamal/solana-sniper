# ═══════════════════════════════════════════════════
#   SOLANA SNIPER — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════

# ── SAFETY: Start in dry run mode ───────────────────
# Set to false ONLY when you're ready for live trading
DRY_RUN=true

# ── WALLET ──────────────────────────────────────────
# Your Solana wallet private key (base58 or JSON array)
# NEVER commit this file to git!
WALLET_PRIVATE_KEY=

# ── RPC ENDPOINT ────────────────────────────────────
# Free: https://api.mainnet-beta.solana.com
# Recommended (faster): Get free key at https://helius.dev
# Premium: QuickNode https://quicknode.com
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
RPC_WS_ENDPOINT=wss://api.mainnet-beta.solana.com

# ── CAPITAL SETTINGS ────────────────────────────────
INITIAL_CAPITAL_USD=100.0

# ── RISK PARAMETERS ──────────────────────────────────
# Max % of capital per single trade (0.10 = 10%)
MAX_POSITION_PCT=0.10

# Stop loss percentage (0.15 = 15%)
STOP_LOSS_PCT=0.15

# Minimum DEX liquidity in USD
MIN_LIQUIDITY_USD=30000.0

# Minimum 24h volume in USD
MIN_VOLUME_24H=10000.0

# Maximum token age in hours
MAX_AGE_HOURS=72.0

# Minimum token score (0-100) to auto-trade
MIN_SCORE=60

# Max concurrent open positions
MAX_OPEN_POSITIONS=5

# ── EXECUTION ────────────────────────────────────────
# Slippage tolerance in basis points (300 = 3%)
SLIPPAGE_BPS=300

# Priority fee in lamports for fast landing
# 500000 = 0.0005 SOL per tx (~$0.07 at $140/SOL)
PRIORITY_FEE_LAMPORTS=500000

# ── TELEGRAM ALERTS (optional) ───────────────────────
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── SERVER ───────────────────────────────────────────
PORT=8080
RUST_LOG=solana_sniper=info
